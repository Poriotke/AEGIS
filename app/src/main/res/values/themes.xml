<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AEGIS" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryContainer">@color/surface_variant</item>
        <item name="colorOnPrimary">@color/surface</item>
        <item name="android:colorBackground">@color/surface</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.AEGIS.LockOverlay" parent="Theme.AEGIS">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@color/lock_bg</item>
    </style>

    <style name="PinButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@color/surface_variant</item>
        <item name="cornerRadius">40dp</item>
    </style>
</resources>